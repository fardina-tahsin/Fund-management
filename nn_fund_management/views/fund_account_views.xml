<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">fund.account.form</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">fund.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_fund_management_root"
              name="Fund Management"
              sequence="10"/>

    <menuitem id="menu_fund_accounts"
              name="Fund Accounts"
              parent="menu_fund_management_root"
              action="action_fund_account"
              sequence="10"/>
</odoo>