<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">fund.account.form</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Account Info">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="account_type"/>
                            <field name="currency_id"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Balances">
                            <field name="total_received"/>
                            <field name="unassigned_balance"/>
                            <field name="on_hold_balance"/>
                            <field name="assigned_balance"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fund_account_list" model="ir.ui.view">
        <field name="name">fund.account.list</field>
        <field name="model">fund.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="account_type"/>
                <field name="currency_id"/>
                <field name="total_received"/>
                <field name="unassigned_balance"/>
                <field name="on_hold_balance"/>
                <field name="assigned_balance"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_incoming_form" model="ir.ui.view">
        <field name="name">fund.incoming.form</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Transaction Info">
                            <field name="name" readonly="1"/>
                            <field name="fund_account_id"/>
                            <field name="transaction_reference"/>
                            <field name="transaction_date"/>
                            <field name="sender"/>
                        </group>
                        <group string="Amount">
                            <field name="currency_id" invisible="1"/>
                            <field name="amount"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group string="Additional Info">
                        <field name="description"/>
                        <field name="attachment" filename="attachment_name"/>
                        <field name="attachment_name" invisible="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fund_incoming_list" model="ir.ui.view">
        <field name="name">fund.incoming.list</field>
        <field name="model">fund.incoming</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="transaction_date"/>
                <field name="transaction_reference"/>
                <field name="sender"/>
                <field name="amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">fund.account</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_fund_incoming" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">fund.incoming</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_fund_management_root"
              name="Fund Management"
              sequence="10"/>

    <menuitem id="menu_fund_accounts"
              name="Fund Accounts"
              parent="menu_fund_management_root"
              action="action_fund_account"
              sequence="10"/>

    <menuitem id="menu_fund_incoming"
              name="Incoming Funds"
              parent="menu_fund_management_root"
              action="action_fund_incoming"
              sequence="20"/>

</odoo>