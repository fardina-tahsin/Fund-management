<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_audit_log_list" model="ir.ui.view">
        <field name="name">fund.audit.log.list</field>
        <field name="model">fund.audit.log</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="create_date" string="Date"/>
                <field name="name" string="Reference"/>
                <field name="model_name" string="Document Type"/>
                <field name="user_id" string="User"/>
                <field name="action"/>
                <field name="previous_state"/>
                <field name="new_state"/>
                <field name="amount"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="comment"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_audit_log_form" model="ir.ui.view">
        <field name="name">fund.audit.log.form</field>
        <field name="model">fund.audit.log</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group string="Action Info">
                            <field name="name" string="Reference"/>
                            <field name="model_name" string="Document Type"/>
                            <field name="action"/>
                            <field name="user_id"/>
                            <field name="create_date" string="Date"/>
                        </group>
                        <group string="Status Change">
                            <field name="previous_state"/>
                            <field name="new_state"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group string="Related Records">
                        <field name="fund_account_id"/>
                        <field name="project_id"/>
                        <field name="expense_head_id"/>
                        <field name="record_ref"/>
                    </group>
                    <group string="Comment">
                        <field name="comment" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">fund.audit.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_fund_audit_log"
              name="Audit Log"
              parent="menu_fund_management_root"
              action="action_fund_audit_log"
              sequence="80"/>

</odoo>