<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fund_transfer_form" model="ir.ui.view">
        <field name="name">fund.transfer.form</field>
        <field name="model">fund.transfer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_gm_approve" string="GM Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"/>
                    <button name="action_md_approve" string="MD Approve"
                            type="object" class="btn-primary"
                            invisible="state != 'gm_approved'"/>
                    <button name="action_reject" string="Reject"
                            type="object"
                            invisible="state not in ('submitted', 'gm_approved')"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'submitted', 'gm_approved')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approved,approved"/>
                </header>
                <sheet>
                    <group>
                        <group string="Transfer Info">
                            <field name="name" readonly="1"/>
                            <field name="request_date"/>
                            <field name="requested_by"/>
                            <field name="company_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="amount"/>
                        </group>
                        <group string="Source">
                            <field name="source_project_id"/>
                            <field name="source_expense_head_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Destination">
                            <field name="dest_project_id"/>
                            <field name="dest_expense_head_id"/>
                        </group>
                        <group string="Approvals">
                            <field name="gm_approver_id" readonly="1"/>
                            <field name="gm_approval_date" readonly="1"/>
                            <field name="md_approver_id" readonly="1"/>
                            <field name="md_approval_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1" colspan="2"/>
                    </group>
                    <notebook>
                        <page string="GM Comment">
                            <field name="gm_comment"/>
                        </page>
                        <page string="MD Comment">
                            <field name="md_comment"/>
                        </page>
                        <page string="Approval History">
                            <field name="approval_history_ids" readonly="1">
                                <tree>
                                    <field name="user_id"/>
                                    <field name="action"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fund_transfer_list" model="ir.ui.view">
        <field name="name">fund.transfer.list</field>
        <field name="model">fund.transfer</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="source_project_id"/>
                <field name="source_expense_head_id"/>
                <field name="dest_project_id"/>
                <field name="dest_expense_head_id"/>
                <field name="amount"/>
                <field name="request_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_fund_transfer" model="ir.actions.act_window">
        <field name="name">Fund Transfers</field>
        <field name="res_model">fund.transfer</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_fund_transfer"
              name="Fund Transfers"
              parent="menu_fund_management_root"
              action="action_fund_transfer"
              sequence="60"/>

</odoo>