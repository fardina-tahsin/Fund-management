<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_fund_user" model="res.groups">
        <field name="name">Fund User</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="comment">Can create and view fund requests.</field>
    </record>

    <record id="group_fund_finance" model="res.groups">
        <field name="name">Fund Finance User</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
        <field name="comment">Can confirm incoming funds.</field>
    </record>

    <record id="group_fund_gm" model="res.groups">
        <field name="name">Fund GM Approver</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
        <field name="comment">Can perform GM level approvals.</field>
    </record>

    <record id="group_fund_md" model="res.groups">
        <field name="name">Fund MD Approver</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_gm'))]"/>
        <field name="comment">Can perform MD level approvals.</field>
    </record>

    <record id="group_fund_admin" model="res.groups">
        <field name="name">Fund Administrator</field>
        <field name="category_id" ref="base.module_category_accounting_accounting"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_md')), (4, ref('group_fund_finance'))]"/>
        <field name="comment">Full access to all fund management features.</field>
    </record>

</odoo>