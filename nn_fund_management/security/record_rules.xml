<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Fund Account: users see only their company -->
    <record id="rule_fund_account_company" model="ir.rule">
        <field name="name">Fund Account: Company</field>
        <field name="model_id" ref="model_fund_account"/>
        <field name="domain_force">[('company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_fund_user'))]"/>
    </record>

